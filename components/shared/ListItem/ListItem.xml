<?xml version="1.0" encoding="utf-8" ?>
<component name="ListItem" extends="Group">
  <script type="text/brightscript" uri="pkg:/components/shared/DialogStyle/DialogStyle.brs" />
  <script type="text/brightscript" uri="pkg:/components/shared/ListItem/ListItem.brs" />

	<interface>
 		<field id="itemContent" type="node" onChange="itemContentChanged" />
		<field id="itemHasFocus" type="bool" onChange="updateFocus" />
	</interface>

	<children>
		<Rectangle
			id="focusBackground"
			width="1500"
			height="120"
			color="0x2E2E2EFF"
			visible="false"
		/>

		<LayoutGroup
			layoutDirection="horiz"
			vertAlignment="center"
			translation="[0, 55]"
			itemSpacings="32"
		>
			<Poster
				id="icon"
				width="50"
				height="50"
				loadDisplayMode="scaleToFit"
				uri="pkg:/images/Spinner.png"
			/>

			<Label
				id="title"
				font="font:MediumBoldSystemFont"
				color="0xEDEDEDFF"
			/>

			<Label
				id="description"
				font="font:SmallSystemFont"
				color="0xA0A0A0FF"
			/>
		</LayoutGroup>
	</children>
</component>
