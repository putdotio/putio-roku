<?xml version="1.0" encoding="utf-8" ?>

<component name="VideoConversionStatus" extends="Group">
  <interface>
    <field id="fileId" type="integer" />
    <field id="fileName" type="string" onChange="onFileNameChange" />
    <field id="control" type="string" onChange="onControlChange" />
    <field id="completedFile" type="assocarray" />
    <field id="completed" type="bool" alwaysNotify="true" />
    <field id="dismissed" type="bool" alwaysNotify="true" />
    <field id="previewMode" type="string" onChange="onPreviewModeChange" />
  </interface>

  <script type="text/brightscript" uri="pkg:/components/shared/DialogStyle/DialogStyle.brs" />
  <script type="text/brightscript" uri="pkg:/components/shared/VideoConversionStatus/VideoConversionStatus.brs" />

  <children>
    <Rectangle
      id="backdrop"
      width="1920"
      height="1080"
      color="0x000000B8"
    />

    <Group
      id="panel"
      translation="[560,318]"
    >
      <Rectangle
        id="panelShadow"
        translation="[12,12]"
        width="800"
        height="420"
        color="0x00000080"
      />

      <Rectangle
        id="panelFill"
        width="800"
        height="420"
        color="0x202020FF"
      />

      <Rectangle
        id="panelBorderTop"
        width="800"
        height="1"
        color="0x4A4A4AFF"
        visible="false"
      />

      <Rectangle
        id="panelBorderRight"
        translation="[799,0]"
        width="1"
        height="420"
        color="0x4A4A4AFF"
        visible="false"
      />

      <Rectangle
        id="panelBorderBottom"
        translation="[0,419]"
        width="800"
        height="1"
        color="0x4A4A4AFF"
        visible="false"
      />

      <Rectangle
        id="panelBorderLeft"
        width="1"
        height="420"
        color="0x4A4A4AFF"
        visible="false"
      />

      <Label
        id="title"
        translation="[64,54]"
        width="672"
        font="font:LargeBoldSystemFont"
        color="0xEDEDEDFF"
        text="Preparing video"
      />

      <Label
        id="fileNameLabel"
        translation="[64,112]"
        width="672"
        height="64"
        font="font:SmallSystemFont"
        color="0xA0A0A0FF"
        wrap="true"
      />

      <LoadingIndicator
        id="spinner"
        translation="[356,182]"
        centered="false"
        width="88"
        height="88"
        imageWidth="64"
        imageHeight="64"
      />

      <Group
        id="progressGroup"
        translation="[64,202]"
        visible="false"
      >
        <Rectangle
          id="progressTrack"
          width="672"
          height="8"
          color="0x343434FF"
        />
        <Rectangle
          id="progressFill"
          width="0"
          height="8"
          color="0xFDCE45FF"
        />
      </Group>

      <Label
        id="statusLabel"
        translation="[64,244]"
        width="672"
        font="font:MediumSystemFont"
        color="0xA0A0A0FF"
        horizAlign="center"
        text="Checking conversion status..."
      />

      <Group
        id="actionButton"
        translation="[240,324]"
      >
        <Rectangle
          id="actionBackground"
          width="320"
          height="64"
          color="0x2E2E2EFF"
        />
        <Label
          id="actionLabel"
          translation="[0,15]"
          width="320"
          font="font:MediumBoldSystemFont"
          color="0xEDEDEDFF"
          horizAlign="center"
          text="Cancel"
        />
      </Group>
    </Group>
  </children>
</component>
