<?xml version="1.0" encoding="utf-8" ?>
<component name="HistoryScreen" extends="Group">
  <script type="text/brightscript" uri="pkg:/components/shared/DialogStyle/DialogStyle.brs" />
  <script type="text/brightscript" uri="pkg:/components/shared/utils.brs" />
  <script type="text/brightscript" uri="pkg:/components/shared/KeyUtils.brs" />
  <script type="text/brightscript" uri="pkg:/components/screens/History/History.brs" />

  <interface>
    <field id="params" type="assocarray" />
    <field id="routeShown" type="boolean" alwaysNotify="true" />
    <field id="routeHidden" type="boolean" alwaysNotify="true" />
    <field id="navigate" type="assocarray" />
    <field id="navigateBack" type="bool" alwaysNotify="true" />
    <field id="showDialog" type="node" alwaysNotify="true" />
  </interface>

  <children>
    <Overhang
      id="overhang"
      showClock="false"
      title="History"
      logoUri="pkg:/images/OverhangLogo.png"
      logoBaselineOffset="9"
      showOptions="true"
      optionsAvailable="false"
      optionsDimColor="0x00000000"
      optionsIconDimColor="0x00000000"
    />

    <LoadingIndicator
      id="loading"
      imageWidth="120"
      imageHeight="120"
    />

    <MarkupList
      id="historyList"
      translation="[102, 190]"
      itemComponentName="HistoryListItem"
      itemSize="[1720, 120]"
      itemSpacing="[0, 30]"
      drawFocusFeedback="true"
      drawFocusFeedbackOnTop="false"
      focusBitmapUri="pkg:/images/list-item-focus.9.png"
      focusBitmapBlendColor="0x2E2E2EFF"
      vertFocusAnimationStyle="fixedFocus"
      numRows="6"
    />

    <EmptyState
      id="emptyState"
      translation="[190, 300]"
      contentWidth="1500"
      visible="false"
      headingText="This is your history. It's currently empty."
      bodyText="You will see information here once things start happening."
    />
  </children>
</component>
