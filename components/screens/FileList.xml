<?xml version="1.0" encoding="utf-8" ?>
<component name="FileListScreen" extends="Group">
  <script type="text/brightscript" uri="pkg:/components/screens/FileList.brs" />

	<interface>
    <field id="params" type="assocarray" />
		<field id="navigate" type="assocarray" />
  </interface>

	<children>
		<Overhang
			id="overhang"
			showClock="false"
      title="Your Files"
		/>

		<MarkupList
			id="fileList"
			itemComponentName="FileListItem"
			translation="[210, 190]"
			itemSize="[1500, 120]"
			itemSpacing="[0, 40]"
			focusBitmapBlendColor="0x00000FF"
		/>
	</children>
</component>
