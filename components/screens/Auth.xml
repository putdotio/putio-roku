<?xml version="1.0" encoding="utf-8" ?>
<component name="AuthScreen" extends="Group">
  <script type="text/brightscript" uri="pkg:/components/screens/Auth.brs" />

  <interface>
    <field id="token" type="string" />
		<field id="showExitAppDialog" type="boolean" value="false" alwaysNotify="true" />
  </interface>

	<children>
		<LayoutGroup
			layoutDirection="vert"
			horizAlignment="center"
			translation="[960, 140]"
			itemSpacings="120"
		>
			<Poster
				id="welcome"
				width="960"
				height="240"
				loadDisplayMode="scaleToFit"
				uri="pkg:/images/AuthWelcome.png"
			/>

      <Label
        id="description"
        font="font:MediumSystemFont"
        color="0xFFFFFFFF"
				text="Please go to put.io/link and activate your device by using the code below"
      />

			<Group>
				<Rectangle
					color="0x000000FF"
					width="360"
					height="120"
				/>

				<Label
					id="code"
					text="Loading..."
					font="font:LargeBoldSystemFont"
					width="360"
					height="120"
					horizAlign="center"
					vertAlign="center"
				/>
			</Group>
		</LayoutGroup>
	</children>
</component>
