<?xml version="1.0" encoding="utf-8" ?>
<component name="FilesScreen" extends="Group">
  <script type="text/brightscript" uri="pkg:/components/screens/Files/Files.brs" />

	<interface>
    <field id="params" type="assocarray" />
		<field id="navigate" type="assocarray" />
		<field id="showDialog" type="node" alwaysNotify="true" />
  </interface>

	<children>
		<Overhang
			id="overhang"
			showClock="false"
      title="Your Files"
			logoUri="pkg:/images/OverhangLogo.png"
			logoBaselineOffset="9"
			showOptions="true"
			optionsAvailable="false"
			optionsText=""
		/>

		<MarkupList
			id="fileList"
			translation="[190, 190]"
			itemComponentName="FileListItem"
			itemSize="[1500, 120]"
			itemSpacing="[0, 30]"
			focusBitmapBlendColor="0x00000FF"
			vertFocusAnimationStyle="floatingFocus"
			numRows="6"
		/>
	</children>
</component>
