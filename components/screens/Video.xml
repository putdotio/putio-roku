<?xml version="1.0" encoding="utf-8" ?>
<component name="VideoScreen" extends="Group">
  <script type="text/brightscript" uri="pkg:/components/screens/Video.brs" />

	<interface>
    <field id="params" type="assocarray" />
		<field id="navigate" type="assocarray" />
  </interface>

	<children>
		<Overhang
			id="overhang"
			showClock="false"
      title="Your Files"
			logoUri="pkg:/images/OverhangLogo.png"
			logoBaselineOffset="9"
			showOptions="true"
			optionsAvailable="false"
			optionsDimColor="0x00000000"
			optionsIconDimColor="0x00000000"
		/>

    <LoadingIndicator
      id="loading"
      clockwise="false"
      spinInterval="4"
      text="Loading"
      spacing="60"
      imageWidth="120"
      imageHeight="120"
      centered="true"
      font="font:LargeSystemFont"
      backgroundOpacity="0"
      height="240"
    />

    <LayoutGroup
      id="content"
      translation="[190, 190]"
      itemSpacings="80"
    >
      <LayoutGroup
        itemSpacings="80"
      >
        <LayoutGroup
          layoutDirection="horiz"
          vertAlignment="center"
          itemSpacings="70"
        >
          <Poster
            id="button-play"
            uri="pkg:/images/PlayButtonFocused.png"
            width="350"
            height="140"
          />

          <Group id="next-video">
            <Poster
              id="next-video-background"
              uri="pkg:/images/NextVideoUnfocused.png"
              width="1120"
              height="140"
            />

            <Label
              id="next-video-title"
              text="UP NEXT"
              font="font:SmallSystemFont"
              color="0xFFFFFFFF"
              translation="[35, 20]"
            />

            <Label
              id="next-video-label"
              text="Loading..."
              font="font:SmallSystemFont"
              color="0xFFFFFFFF"
              translation="[35, 70]"
              width="960"
            />
          </Group>
        </LayoutGroup>
      </LayoutGroup>

      <LayoutGroup
        itemSpacings="20"
      >
        <Label
          text="SUBTITLES"
          font="font:SmallSystemFont"
          color="0xFFFFFFFF"
        />

        <RadioButtonList
          id="subtitleList"
          checkedItem="0"
          color="0xFFFFFFFF"
          focusedColor="0xFFFFFFFF"
          focusBitmapBlendColor="0x00000FF"
          itemSize="[1550, 80]"
          checkedIconUri="pkg:/images/icons/checkmark.png"
          focusedCheckedIconUri="pkg:/images/icons/checkmark.png"
          vertFocusAnimationStyle="floatingFocus"
          numRows="6"
          font="font:MediumSystemFont"
          focusedFont="font:MediumSystemFont"
        />
      </LayoutGroup>
    </LayoutGroup>
	</children>
</component>
