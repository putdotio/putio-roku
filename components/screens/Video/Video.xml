<?xml version="1.0" encoding="utf-8" ?>
<component name="VideoScreen" extends="Group">
  <script type="text/brightscript" uri="pkg:/components/shared/DialogStyle/DialogStyle.brs" />
  <script type="text/brightscript" uri="pkg:/components/shared/PlaybackConfig.brs" />
  <script type="text/brightscript" uri="pkg:/components/shared/PlaybackUtils.brs" />
  <script type="text/brightscript" uri="pkg:/components/shared/KeyUtils.brs" />
  <script type="text/brightscript" uri="pkg:/components/screens/Video/Video.brs" />

	<interface>
    <field id="params" type="assocarray" />
    <field id="routeShown" type="boolean" alwaysNotify="true" />
    <field id="routeHidden" type="boolean" alwaysNotify="true" />
		<field id="navigate" type="assocarray" />
		<field id="navigateBack" type="bool" alwaysNotify="true" />
		<field id="showDialog" type="node" alwaysNotify="true" />
  </interface>

	<children>
		<Overhang
			id="overhang"
			translation="[0, 8]"
			showClock="false"
      title=""
			logoUri="pkg:/images/OverhangLogo.png"
			logoBaselineOffset="9"
			showOptions="true"
			optionsAvailable="false"
			optionsDimColor="0x00000000"
			optionsIconDimColor="0x00000000"
		/>

    <Poster
      id="customTitleDot"
      translation="[314, 69]"
      width="12"
      height="51"
      uri="/RokuOS/Artwork/SceneGraph/GenevaTheme/Base/FHD/divider_vertical.webp"
    />

    <Label
      id="customTitle"
      translation="[350, 69]"
      text=""
      font="font:LargeBoldSystemFont"
      color="0xEDEDEDFF"
    />

    <LoadingIndicator
      id="loading"
      imageWidth="120"
      imageHeight="120"
    />

    <VideoConversionStatus
      id="conversionStatus"
      visible="false"
    />

    <ContinueWatchingPrompt
      id="continueWatchingPrompt"
      visible="false"
    />
	</children>
</component>
