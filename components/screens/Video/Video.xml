<?xml version="1.0" encoding="utf-8" ?>
<component name="VideoScreen" extends="Group">
  <script type="text/brightscript" uri="pkg:/components/screens/Video/Video.brs" />

	<interface>
    <field id="params" type="assocarray" />
		<field id="navigate" type="assocarray" />
		<field id="navigateBack" type="bool" alwaysNotify="true" />
		<field id="showDialog" type="node" alwaysNotify="true" />
  </interface>

	<children>
		<Overhang
			id="overhang"
			showClock="false"
      title="Your Files"
			logoUri="pkg:/images/OverhangLogo.png"
			logoBaselineOffset="9"
			showOptions="true"
			optionsAvailable="false"
			optionsDimColor="0x00000000"
			optionsIconDimColor="0x00000000"
		/>

    <LoadingIndicator
      id="loading"
      imageWidth="120"
      imageHeight="120"
    />

    <LayoutGroup
      id="content"
      translation="[190, 190]"
      itemSpacings="96"
      layoutDirection="horiz"
    >
      <Poster
        id="poster"
        width="720"
        height="480"
        loadingBitmapUri="pkg:/images/Splash-Blank-SD.png"
        failedBitMapUri="pkg:/images/Splash-Blank-SD.png"
      />

      <LayoutGroup itemSpacings="84">
        <Poster
          id="button-play"
          uri="pkg:/images/PlayButtonFocused.png"
          width="312"
          height="140"
        />

        <LayoutGroup itemSpacings="16">
          <Label
            text="SUBTITLES"
            font="font:SmallestSystemFont"
            color="0xFFFFFFFF"
          />

          <RadioButtonList
            id="subtitleList"
            checkedItem="0"
            color="0xFFFFFFFF"
            focusedColor="0xFFFFFFFF"
            focusBitmapBlendColor="0x00000FF"
            itemSize="[720, 96]"
            focusedCheckedIconUri="pkg:/images/icons/checkmark.png"
            vertFocusAnimationStyle="floatingFocus"
            numRows="6"
            font="font:MediumSystemFont"
            focusedFont="font:MediumSystemFont"
          />
        </LayoutGroup>
      </LayoutGroup>
    </LayoutGroup>
	</children>
</component>
