<?xml version="1.0" encoding="utf-8" ?>
<component name="AudioScreen" extends="Group">
  <script type="text/brightscript" uri="pkg:/components/shared/DialogStyle/DialogStyle.brs" />
  <script type="text/brightscript" uri="pkg:/components/shared/KeyUtils.brs" />
  <script type="text/brightscript" uri="pkg:/components/screens/Audio/Audio.brs" />

	<interface>
    <field id="params" type="assocarray" />
    <field id="routeShown" type="boolean" alwaysNotify="true" />
    <field id="routeHidden" type="boolean" alwaysNotify="true" />
		<field id="navigate" type="assocarray" />
		<field id="navigateBack" type="bool" alwaysNotify="true" />
    <field id="showDialog" type="node" alwaysNotify="true" />
  </interface>

	<children>
    <Overhang
      id="overhang"
      translation="[0, 8]"
      showClock="false"
      title=""
      logoUri="pkg:/images/OverhangLogo.png"
      logoBaselineOffset="9"
      showOptions="true"
      optionsAvailable="false"
      optionsDimColor="0x00000000"
      optionsIconDimColor="0x00000000"
	  />

    <Poster
      id="customTitleDot"
      translation="[314, 69]"
      width="12"
      height="51"
      uri="/RokuOS/Artwork/SceneGraph/GenevaTheme/Base/FHD/divider_vertical.webp"
    />

    <Label
      id="customTitle"
      translation="[350, 69]"
      text=""
      font="font:LargeBoldSystemFont"
      color="0xEDEDEDFF"
    />

    <LayoutGroup
      id="audioPlayer"
      itemSpacings="96"
      layoutDirection="vert"
    >
      <LayoutGroup
        id="controls"
        itemSpacings="96"
        layoutDirection="horiz"
        vertAlignment="center"
      >
        <Poster
          id="rewind"
          width="96"
          height="96"
          uri="pkg:/images/icons/goback15.png"
          audioGuideText="Rewind"
        />
        <Poster
          id="play"
          width="128"
          height="128"
          uri="pkg:/images/icons/play-4.png"
          audioGuideText="Play or Pause"
        />
        <Poster
          id="fastforward"
          width="96"
          height="96"
          uri="pkg:/images/icons/goforward15.png"
          audioGuideText="Fast Forward"
        />
      </LayoutGroup>
    </LayoutGroup>

    <LayoutGroup
        id="progress"
        itemSpacings="32"
        layoutDirection="horiz"
        vertAlignment="center"
      >
        <Label
					id="position"
					font="font:MediumBoldSystemFont"
					color="0xEDEDEDFF"
					text="..:.."
					width="128"
				/>

        <ProgressBar
          id="progressBar"
          width="960"
          emptyBarBlendColor="0x343434FF"
          filledBarBlendColor="0xFDCE45FF"
        />

        <Label
					id="duration"
					font="font:MediumBoldSystemFont"
					color="0xEDEDEDFF"
					text="..:.."
					width="128"
				/>
      </LayoutGroup>

    <LoadingIndicator
      id="loading"
      imageWidth="120"
      imageHeight="120"
      visible="true"
    />

    <Audio id="audio" />
	</children>
</component>
