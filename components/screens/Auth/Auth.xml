<?xml version="1.0" encoding="utf-8" ?>
<component name="AuthScreen" extends="Group">
  <script type="text/brightscript" uri="pkg:/components/screens/Auth/Auth.brs" />

  <interface>
		<field id="params" type="assocarray" />
    <field id="token" type="string" value="" />
		<field id="showExitAppDialog" type="boolean" value="false" alwaysNotify="true" />
  </interface>

	<children>
		<LayoutGroup
			layoutDirection="vert"
			horizAlignment="center"
			translation="[960, 120]"
			itemSpacings="96"
		>
			<Poster
				id="welcome"
				width="960"
				height="240"
				loadDisplayMode="scaleToFit"
				uri="pkg:/images/AuthWelcome.png"
			/>

      <Label
        id="description"
        font="font:MediumSystemFont"
        color="0xFFFFFFFF"
				width="1280"
				text="Please go to [put.io/link] in your web browser or navigate to [Settings -> Link your device] section of Putio iOS app and activate this device with the following code"
				wrap="true"
				horizAlign="center"
				vertAlign="center"
				lineSpacing="20.0"
      />

			<LayoutGroup
				layoutDirection="vert"
				horizAlignment="center"
				itemSpacings="20"
			>
				<Group>
					<Rectangle
						color="0x000000FF"
						width="360"
						height="120"
					/>

					<Label
						id="code"
						text="Loading..."
						font="font:LargeBoldSystemFont"
						width="360"
						height="120"
						horizAlign="center"
						vertAlign="center"
					/>
				</Group>

				<Label
					id="message"
					text=""
					width="960"
					wrap="true"
					horizAlign="center"
					vertAlign="center"
					lineSpacing="10.0"
					font="font:SmallSystemFont"
				/>
			</LayoutGroup>
		</LayoutGroup>
	</children>
</component>
